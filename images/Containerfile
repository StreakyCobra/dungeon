FROM docker.io/archlinux:latest

# Update and install packages
RUN pacman -Syu --noconfirm \
    && pacman -S --noconfirm \
      bubblewrap \
      ca-certificates \
      curl \
      git \
      less \
      nvim \
      ipset \
      iptables \
      nodejs \
      npm \
      python \
      python-uv \
      ripgrep \
      rustup \
      sudo \
      terraform \
      which \
    && rm -rf /var/cache/pacman/pkg /var/lib/pacman/sync/*

# Setup user
RUN groupadd -g 1000 dungeon && \
    useradd -m -u 1000 -g 1000 dungeon && \
    install -d -o dungeon -g dungeon \
      /home/dungeon/.cache \
      /home/dungeon/.config \
      /home/dungeon/.local \
      /home/dungeon/.local/share \
      /home/dungeon/.local/state \
      /home/dungeon/.npm-global && \
    mkdir -p /workspace && \
    chmod 4755 /usr/bin/bwrap && \
    install -d /etc/sudoers.d && \
    printf 'dungeon ALL=(root) NOPASSWD: /usr/local/bin/dungeon-install\n' > /etc/sudoers.d/dungeon-install && \
    chmod 0440 /etc/sudoers.d/dungeon-install

COPY images/dungeon-bootstrap /usr/local/bin/dungeon-bootstrap
COPY images/dungeon-install /usr/local/bin/dungeon-install
RUN chmod 0755 /usr/local/bin/dungeon-bootstrap /usr/local/bin/dungeon-install

USER dungeon

WORKDIR /workspace

ENV NPM_CONFIG_PREFIX=/home/dungeon/.npm-global
ENV PATH=/home/dungeon/.npm-global/bin:$PATH

# Setup git
RUN git config --global user.name "dungeon" && \
    git config --global user.email "dungeon@example.com"

# Install AI agents
RUN npm i -g @openai/codex@latest \
    && npm i -g opencode-ai@1.14.48 \
    && rm -rf /home/dungeon/.npm

ENTRYPOINT ["/usr/local/bin/dungeon-bootstrap"]
