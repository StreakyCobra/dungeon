#!/usr/bin/env zsh
setopt errexit nounset pipefail
IFS=$'\n\t'

if (( $# == 0 )); then
    set -- zsh
fi

# libkrun can start the OCI entrypoint as root even when Podman was given
# --user dungeon. Native runtimes already enter here as the requested user.
if (( EUID != 0 )); then
    exec "$@"
fi

if tty_path=$(tty 2>/dev/null) && [[ -c $tty_path ]]; then
    chown dungeon "$tty_path" 2>/dev/null || true
    chmod u+rw "$tty_path" 2>/dev/null || true
fi

exec env HOME=/home/dungeon USER=dungeon LOGNAME=dungeon \
    setpriv \
    --reuid dungeon \
    --regid dungeon \
    --init-groups \
    --inh-caps=-all \
    --ambient-caps=-all \
    -- "$@"
