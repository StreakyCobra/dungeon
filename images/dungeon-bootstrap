#!/usr/bin/env bash
set -euo pipefail
IFS=$'\n\t'

runtime_user="${DUNGEON_RUNTIME_USER:-dungeon}"
ipv6_enabled="${DUNGEON_IPV6:-0}"
allow_dns="${DUNGEON_ALLOW_DNS:-1}"
allowed_domains_raw="${DUNGEON_ALLOWED_TCP_DOMAINS:-}"
allowed_hosts_raw="${DUNGEON_ALLOWED_TCP_HOSTS:-}"

if [ "$#" -eq 0 ]; then
    set -- zsh
fi

read_csv_values() {
    local raw="$1"
    printf '%s\n' "$raw" | tr ', ' '\n\n' | sed '/^$/d' | sort -u
}

configure_open_ipv4() {
    iptables -F
    iptables -X
    iptables -P INPUT ACCEPT
    iptables -P FORWARD ACCEPT
    iptables -P OUTPUT ACCEPT

    if [ "$allow_dns" != "1" ]; then
        iptables -A OUTPUT -p udp --dport 53 -j REJECT --reject-with icmp-port-unreachable
        iptables -A OUTPUT -p tcp --dport 53 -j REJECT --reject-with icmp-port-unreachable
    fi
}

configure_open_ipv6() {
    ip6tables -F
    ip6tables -X

    if [ "$ipv6_enabled" != "1" ]; then
        ip6tables -P INPUT DROP
        ip6tables -P FORWARD DROP
        ip6tables -P OUTPUT DROP
        return
    fi

    ip6tables -P INPUT ACCEPT
    ip6tables -P FORWARD ACCEPT
    ip6tables -P OUTPUT ACCEPT

    if [ "$allow_dns" != "1" ]; then
        ip6tables -A OUTPUT -p udp --dport 53 -j REJECT --reject-with icmp6-port-unreachable
        ip6tables -A OUTPUT -p tcp --dport 53 -j REJECT --reject-with icmp6-port-unreachable
    fi
}

configure_restricted_ipv4() {
    iptables -F
    iptables -X
    ipset destroy dungeon-allowed4 2>/dev/null || true
    ipset create dungeon-allowed4 hash:net family inet

    iptables -P INPUT DROP
    iptables -P FORWARD DROP
    iptables -P OUTPUT DROP
    iptables -A INPUT -i lo -j ACCEPT
    iptables -A OUTPUT -o lo -j ACCEPT
    iptables -A INPUT -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT
    iptables -A OUTPUT -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT

    if [ "$allow_dns" = "1" ]; then
        iptables -A OUTPUT -p udp --dport 53 -j ACCEPT
        iptables -A OUTPUT -p tcp --dport 53 -j ACCEPT
    fi

    iptables -A OUTPUT -p tcp -m set --match-set dungeon-allowed4 dst -j ACCEPT
    iptables -A INPUT -j REJECT --reject-with icmp-port-unreachable
    iptables -A OUTPUT -j REJECT --reject-with icmp-port-unreachable
}

configure_restricted_ipv6() {
    ip6tables -F
    ip6tables -X
    ipset destroy dungeon-allowed6 2>/dev/null || true
    ipset create dungeon-allowed6 hash:net family inet6

    if [ "$ipv6_enabled" != "1" ]; then
        ip6tables -P INPUT DROP
        ip6tables -P FORWARD DROP
        ip6tables -P OUTPUT DROP
        return
    fi

    ip6tables -P INPUT DROP
    ip6tables -P FORWARD DROP
    ip6tables -P OUTPUT DROP
    ip6tables -A INPUT -i lo -j ACCEPT
    ip6tables -A OUTPUT -o lo -j ACCEPT
    ip6tables -A INPUT -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT
    ip6tables -A OUTPUT -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT

    if [ "$allow_dns" = "1" ]; then
        ip6tables -A OUTPUT -p udp --dport 53 -j ACCEPT
        ip6tables -A OUTPUT -p tcp --dport 53 -j ACCEPT
    fi

    ip6tables -A OUTPUT -p tcp -m set --match-set dungeon-allowed6 dst -j ACCEPT
    ip6tables -A INPUT -j REJECT --reject-with icmp6-port-unreachable
    ip6tables -A OUTPUT -j REJECT --reject-with icmp6-port-unreachable
}

add_allowed_host() {
    local host="$1"
    if [[ "$host" == *:* ]]; then
        ipset add dungeon-allowed6 "$host" -exist
    else
        ipset add dungeon-allowed4 "$host" -exist
    fi
}

add_allowed_domain() {
    local domain="$1"
    while read -r line; do
        local ip="${line%%[[:space:]]*}"
        [ -z "$ip" ] && continue
        if [[ "$ip" == *:* ]]; then
            [ "$ipv6_enabled" = "1" ] && ipset add dungeon-allowed6 "$ip" -exist
        else
            ipset add dungeon-allowed4 "$ip" -exist
        fi
    done < <(getent ahosts "$domain" | sort -u)
}

mapfile -t allowed_domains < <(read_csv_values "$allowed_domains_raw")
mapfile -t allowed_hosts < <(read_csv_values "$allowed_hosts_raw")

if [ "${#allowed_domains[@]}" -eq 0 ] && [ "${#allowed_hosts[@]}" -eq 0 ]; then
    configure_open_ipv4
    configure_open_ipv6
else
    configure_restricted_ipv4
    configure_restricted_ipv6

    for host in "${allowed_hosts[@]}"; do
        add_allowed_host "$host"
    done

    for domain in "${allowed_domains[@]}"; do
        add_allowed_domain "$domain"
    done
fi

exec runuser -u "$runtime_user" -- "$@"
